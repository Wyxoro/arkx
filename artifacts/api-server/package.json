{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && export UV_THREADPOOL_SIZE=128 && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "UV_THREADPOOL_SIZE=128 node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@types/node-cache": "^4.2.5",
    "@workspace/api-zod": "workspace:*",
    "anime-sdk": "^1.1.0",
    "axios": "^1.18.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dksanime-api": "^1.8.9",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "node-cache": "^5.1.2",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0"
  }
}
